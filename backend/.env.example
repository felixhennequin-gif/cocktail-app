# =============================================================================
# backend/.env.example — Variables d'environnement du backend Express
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais committer .env dans le dépôt git.
# =============================================================================

# --- Base de données principale (PostgreSQL) ---
# Utilisée par Prisma (prisma.config.ts, src/prisma.js) et les scripts de seed.
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Les caractères spéciaux dans le mot de passe doivent être URL-encodés
# (ex: @ → %40, # → %23, ! → %21).
DATABASE_URL="postgresql://cocktail_user:your_password_here@localhost:5432/cocktails_db"

# --- Base de données de test (PostgreSQL) ---
# Utilisée par Jest (tests/setup.js remplace DATABASE_URL par cette valeur).
# Doit pointer vers une base séparée pour ne pas écraser les données de dev/prod.
DATABASE_TEST_URL="postgresql://cocktail_user:your_password_here@localhost:5432/cocktail_test"

# --- Port du serveur Express ---
# Défaut : 3000 si absent.
PORT=3000

# --- Redis (cache) ---
# Utilisé par src/cache.js (ioredis).
# Défaut : redis://localhost:6379 si absent.
REDIS_URL=redis://localhost:6379

# --- Secret JWT ---
# Utilisé par src/middleware/auth.js pour signer et vérifier les tokens d'authentification.
# Doit être une chaîne aléatoire longue (64+ caractères hex recommandé).
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ATTENTION : changer cette valeur invalide tous les tokens actifs.
JWT_SECRET=your_jwt_secret_here_64_hex_chars_minimum

# =============================================================================
# Webhook GitHub (scripts/webhook-server.js + ecosystem.config.js)
# Ce serveur tourne en processus PM2 séparé (port 9000), indépendant du backend.
# La variable WEBHOOK_SECRET est configurée dans ecosystem.config.js (env du process).
# Documenter ici pour référence.
# =============================================================================

# --- Secret du webhook GitHub ---
# Utilisé par scripts/webhook-server.js pour vérifier la signature HMAC-SHA256
# des requêtes entrantes de GitHub (header X-Hub-Signature-256).
# Doit correspondre exactement au "Secret" configuré côté GitHub :
#   Repo → Settings → Webhooks → Edit → Secret
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WEBHOOK_SECRET=your_github_webhook_secret_here
