generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  pseudo       String    @unique
  passwordHash String
  role         Role      @default(USER)
  avatar       String?
  bio          String?
  createdAt    DateTime  @default(now())
  recipes      Recipe[]
  favorites    Favorite[]
  ratings      Rating[]
  comments     Comment[]
  // follow : gens que cet user suit / gens qui suivent cet user
  following      Follow[]       @relation("Followers")
  followers      Follow[]       @relation("Following")
  notifications  Notification[]
  collections    Collection[]
}

model Recipe {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  imageUrl    String?
  difficulty  Difficulty
  prepTime    Int                // en minutes
  servings    Int?               // nombre de verres/portions
  status      RecipeStatus       @default(PUBLISHED)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  categoryId  Int
  category    Category           @relation(fields: [categoryId], references: [id])
  authorId    Int?
  author      User?              @relation(fields: [authorId], references: [id])
  ingredients RecipeIngredient[]
  steps       Step[]
  favorites     Favorite[]
  ratings       Rating[]
  comments      Comment[]
  searchVector  Unsupported("tsvector")?
  tags          RecipeTag[]
  // Variantes (Feature 4)
  parentRecipeId Int?
  parentRecipe   Recipe?  @relation("RecipeVariants", fields: [parentRecipeId], references: [id])
  variants       Recipe[] @relation("RecipeVariants")
  // Collections (Feature 2)
  collections    CollectionRecipe[]
}

model Category {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  recipes Recipe[]
}

model Ingredient {
  id      Int                @id @default(autoincrement())
  name    String             @unique
  recipes RecipeIngredient[]
}

model RecipeIngredient {
  id           Int        @id @default(autoincrement())
  quantity     Float
  unit         String
  recipeId     Int
  recipe       Recipe     @relation(fields: [recipeId], references: [id])
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
}

model Step {
  id          Int     @id @default(autoincrement())
  order       Int
  description String
  imageUrl    String?
  recipeId    Int
  recipe      Recipe  @relation(fields: [recipeId], references: [id])
}

model Favorite {
  userId    Int
  recipeId  Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  recipe    Recipe   @relation(fields: [recipeId], references: [id])

  @@id([userId, recipeId])
}

model Rating {
  id        Int      @id @default(autoincrement())
  score     Int
  createdAt DateTime @default(now())
  userId    Int
  recipeId  Int
  user      User     @relation(fields: [userId], references: [id])
  recipe    Recipe   @relation(fields: [recipeId], references: [id])

  @@unique([userId, recipeId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int
  recipeId  Int
  user      User     @relation(fields: [userId], references: [id])
  recipe    Recipe   @relation(fields: [recipeId], references: [id])

  @@unique([userId, recipeId])
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())
  // followerId est le "follower" (user qui suit)
  follower    User     @relation("Followers", fields: [followerId], references: [id])
  // followingId est le "following" (user suivi)
  following   User     @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  data      Json
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Tag {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  createdAt DateTime    @default(now())
  recipes   RecipeTag[]
}

model RecipeTag {
  recipeId Int
  tagId    Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([recipeId, tagId])
}

model Collection {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  isPublic    Boolean            @default(true)
  userId      Int
  user        User               @relation(fields: [userId], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  recipes     CollectionRecipe[]
}

model CollectionRecipe {
  collectionId Int
  recipeId     Int
  addedAt      DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([collectionId, recipeId])
}

enum NotificationType {
  NEW_RECIPE
  COMMENT_ON_RECIPE
  RECIPE_APPROVED
  NEW_FOLLOWER
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Role {
  USER
  ADMIN
}

enum RecipeStatus {
  PUBLISHED
  PENDING
  DRAFT
}
